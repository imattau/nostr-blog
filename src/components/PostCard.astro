---
import type { Post, Profile } from "../lib/normalize";

export interface Props {
  post: Post;
  author?: { npub: string; hex: string; profile: Profile } | null;
}

const { post, author } = Astro.props;
const authorProfile = author?.profile;
const authorName = authorProfile?.displayName || authorProfile?.name || "";
const authorPicture = authorProfile?.picture || "";
---

<a
  href={`/post/${post.slug}`}
  class="group block rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden hover:shadow-lg hover:border-gray-300 dark:hover:border-gray-700 transition-all"
>
  {post.image ? (
    <div class="aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-900">
      <img
        src={post.image}
        alt={post.title}
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
      />
    </div>
  ) : null}

  <div class="p-5">
    {authorName ? (
      <div class="flex items-center gap-2 mb-3">
        {authorPicture ? (
          <img src={authorPicture} alt={authorName} class="w-6 h-6 rounded-full object-cover" />
        ) : (
          <div class="w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center text-xs font-bold text-blue-600 dark:text-blue-400">
            {(authorName[0] || "?").toUpperCase()}
          </div>
        )}
        <span class="text-xs text-gray-500 dark:text-gray-400 truncate">{authorName}</span>
      </div>
    ) : null}

    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs text-gray-500 dark:text-gray-400">
        {new Date(post.publishedAt * 1000).toLocaleDateString("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric",
        })}
      </span>
      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">
        {post.kind === 30023 ? "Article" : "Note"}
      </span>
    </div>

    <h3 class="text-lg font-semibold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
      {post.title}
    </h3>

    {post.summary ? (
      <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 leading-relaxed">
        {post.summary}
      </p>
    ) : null}
  </div>
</a>
