---
import BaseLayout from "../layouts/BaseLayout.astro";
import { isSetupComplete, getAuthors } from "../lib/state";

if (!isSetupComplete()) {
  return Astro.redirect("/", 302);
}

const authors = getAuthors();
const siteUrl = Astro.site?.href?.replace(/\/$/, "") || "";
---

<BaseLayout title="Admin" description="Manage blog authors">
  <div class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
    <h1 class="text-3xl font-bold mb-2">Admin</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-10">Manage the authors whose posts appear on this blog.</p>

    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4">Add Author</h2>
      <form id="add-author-form" class="flex gap-3">
        <input
          id="add-npub"
          type="text"
          placeholder="npub1..."
          required
          autocomplete="off"
          spellcheck="false"
          class="flex-1 px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition text-sm"
        />
        <button
          type="submit"
          class="px-6 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition disabled:opacity-50 disabled:cursor-not-allowed text-sm whitespace-nowrap"
        >
          Add Author
        </button>
      </form>
      <p id="add-error" class="text-red-500 text-sm mt-2 hidden"></p>
    </section>

    <section>
      <h2 class="text-xl font-semibold mb-4">Authors ({authors.length})</h2>
      {authors.length === 0 ? (
        <p class="text-gray-500 dark:text-gray-400">No authors configured.</p>
      ) : (
        <ul class="space-y-3">
          {authors.map((a) => (
            <li class="flex items-center justify-between p-4 rounded-lg border border-gray-200 dark:border-gray-800">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-3">
                  {a.profile.picture ? (
                    <img src={a.profile.picture} alt="" class="w-10 h-10 rounded-full object-cover shrink-0" />
                  ) : (
                    <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center shrink-0 text-sm font-bold text-blue-600 dark:text-blue-400">
                      {((a.profile.displayName || a.profile.name || "?")[0]).toUpperCase()}
                    </div>
                  )}
                  <div class="min-w-0">
                    <p class="font-medium truncate">{a.profile.displayName || a.profile.name || "Unknown"}</p>
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-mono truncate">{a.npub}</p>
                  </div>
                </div>
              </div>
              <button
                data-npub={a.npub}
                class="remove-btn ml-4 px-3 py-1.5 rounded-lg text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition shrink-0"
              >
                Remove
              </button>
            </li>
          ))}
        </ul>
      )}
    </section>

    <div class="mt-10 text-center">
      <a href="/" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
        &larr; Back to blog
      </a>
    </div>
  </div>

  <script>
    const form = document.getElementById("add-author-form");
    const input = document.getElementById("add-npub");
    const error = document.getElementById("add-error");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (error) error.classList.add("hidden");
      const btn = e.currentTarget.querySelector("button");
      btn.disabled = true;

      try {
        const res = await fetch("/api/authors", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ npub: input.value.trim() }),
        });
        const data = await res.json();
        if (!res.ok) {
          if (error) {
            error.textContent = data.error || "Failed to add author";
            error.classList.remove("hidden");
          }
          btn.disabled = false;
          return;
        }
        window.location.reload();
      } catch {
        if (error) {
          error.textContent = "Network error";
          error.classList.remove("hidden");
        }
        btn.disabled = false;
      }
    });

    document.querySelectorAll(".remove-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const npub = btn.getAttribute("data-npub");
        if (!npub || !confirm(`Remove this author and all their posts?`)) return;
        btn.disabled = true;

        try {
          const res = await fetch("/api/authors", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ npub }),
          });
          if (res.ok) {
            window.location.reload();
          }
        } catch {
          btn.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>
