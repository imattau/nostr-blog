---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import PostCard from "../components/PostCard.astro";
import AuthorCard from "../components/AuthorCard.astro";
import { isSetupComplete, getCachedData } from "../lib/state";
import { getAuthorByPubkey } from "../lib/graph";
import type { Post, Profile } from "../lib/normalize";
---

{
  isSetupComplete() ? (
    (() => {
      const data = getCachedData();
      const { posts, authors } = data;
      const featured = posts.find((p: Post) => p.image) || posts[0];
      const remaining = posts.filter((p: Post) => p.id !== featured?.id);
      const shownIds = posts.map((p: Post) => p.id);
      const authorPubkeys = authors.map((a: any) => a.hex);
      const oldestTime = posts.length > 0 ? posts[posts.length - 1].publishedAt : null;
      const pageTitle = authors.length === 1
        ? `${authors[0].profile.displayName || authors[0].profile.name || "Home"}'s Blog`
        : "Nostr Blog";
      const pageDesc = authors.length === 1
        ? (authors[0].profile.about || "A blog powered by Nostr")
        : "A multi-author blog powered by Nostr";
      const ogImage = authors.length > 0 ? (authors[0].profile.picture || undefined) : undefined;

      function getPostAuthor(post: Post) {
        return getAuthorByPubkey(post.pubkey);
      }

      return (
        <BaseLayout title={pageTitle} description={pageDesc} ogImage={ogImage}>
          <div class="max-w-5xl mx-auto px-4 py-12 sm:py-16">
            <section class="mb-12">
              <h1 class="sr-only">{pageTitle}</h1>
              <AuthorCard />
            </section>

            <section class="mb-10">
              <form id="search-form" class="relative" role="search" action="/api/search" method="get" onsubmit="return false">
                <input
                  id="search-input"
                  type="search"
                  placeholder="Search posts..."
                  autocomplete="off"
                  class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition text-sm"
                />
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-2 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-xl z-50 max-h-[60vh] overflow-y-auto"></div>
              </form>
            </section>

            {posts.length === 0 ? (
              <div class="text-center py-20">
                <h1 class="text-2xl font-bold mb-4">No posts yet</h1>
                <p class="text-gray-500 dark:text-gray-400">
                  Fetching blog posts from Nostr. Check back soon.
                </p>
              </div>
            ) : (
              <>
                <section class="mb-16">
                  <FeaturedPost post={featured} author={getPostAuthor(featured)} />
                </section>

                {remaining.length > 0 ? (
                  <section>
                    {featured.image ? (
                      <h2 class="text-sm font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-6">
                        More Posts
                      </h2>
                    ) : null}
                    <div id="post-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                      {remaining.map((post: Post) => (
                        <PostCard post={post} author={getPostAuthor(post)} />
                      ))}
                    </div>
                  </section>
                ) : null}

                <div id="load-more-container" class="mt-10 text-center">
                  <button
                    id="load-more-btn"
                    class="px-6 py-3 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition disabled:opacity-50 disabled:cursor-not-allowed"
                    style={{ display: "none" }}
                  >
                    Load More Posts
                  </button>
                  <p id="load-more-status" class="text-sm text-gray-500 dark:text-gray-400 hidden mt-4"></p>
                </div>
              </>
            )}
          </div>

          <script id="nostr-blog-data" type="application/json">
            {JSON.stringify({ authorPubkeys, relays: data.relays, shownIds, oldestTime })}
          </script>

          <script>
            import { fetchOlderPosts, renderPostCard } from "../lib/client";

            const el = document.getElementById("nostr-blog-data");
            const data = JSON.parse(el?.textContent || "{}") as Record<string, unknown>;
            const authorPubkeys = data.authorPubkeys as string[] | undefined;
            const relays = data.relays as string[] | undefined;
            const shownIds = new Set<string>(data.shownIds as string[] || []);
            const grid = document.getElementById("post-grid") as HTMLElement | null;
            const btn = document.getElementById("load-more-btn") as HTMLButtonElement | null;
            const status = document.getElementById("load-more-status") as HTMLElement | null;
            let loading = false;
            let oldestTime = (data.oldestTime as number) || undefined;

            async function loadMore() {
              if (loading || !authorPubkeys?.length || !relays?.length || !btn || !status) return;
              loading = true;
              btn.disabled = true;
              status.textContent = "Loading older posts from Nostr...";
              status.classList.remove("hidden");

              const posts = await fetchOlderPosts(authorPubkeys, relays, oldestTime, shownIds);

              status.classList.add("hidden");
              loading = false;

              if (posts.length === 0) {
                status.textContent = "No more posts found.";
                status.classList.remove("hidden");
                btn.style.display = "none";
                return;
              }

              for (const post of posts) {
                shownIds.add(post.id);
                const div = document.createElement("div");
                div.innerHTML = renderPostCard(post);
                if (grid) grid.appendChild(div.firstElementChild || div);
              }

              oldestTime = posts[posts.length - 1].publishedAt;
              btn.disabled = false;
              btn.style.display = "inline-block";
            }

            if (authorPubkeys?.length && relays?.length && btn) {
              btn.style.display = "inline-block";
              btn.addEventListener("click", loadMore);
            }
          </script>

          <script>
            import { searchPosts } from "../lib/client";

            const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
            const searchResults = document.getElementById("search-results") as HTMLElement | null;
            let searchTimer: ReturnType<typeof setTimeout>;

            searchInput?.addEventListener("input", () => {
              clearTimeout(searchTimer);
              const q = searchInput.value.trim();
              if (!q || q.length < 2) {
                if (searchResults) searchResults.classList.add("hidden");
                return;
              }
              searchTimer = setTimeout(async () => {
                const posts = await searchPosts(q);
                if (!searchResults) return;
                if (posts.length === 0) {
                  searchResults.innerHTML = '<div class="p-4 text-sm text-gray-500">No results found.</div>';
                  searchResults.classList.remove("hidden");
                  return;
                }
                searchResults.innerHTML = posts.map((p: any) => `
                  <a href="/post/${encodeURIComponent(p.slug)}" class="block p-3 hover:bg-gray-50 dark:hover:bg-gray-800 border-b border-gray-100 dark:border-gray-800 last:border-0">
                    <div class="text-sm font-medium">${escapeHtml(p.title)}</div>
                    ${p.summary ? `<div class="text-xs text-gray-500 mt-0.5 line-clamp-1">${escapeHtml(p.summary)}</div>` : ""}
                  </a>
                `).join("");
                searchResults.classList.remove("hidden");
              }, 300);
            });

            document.addEventListener("click", (e) => {
              if (searchResults && !(e.target as HTMLElement).closest("#search-form")) {
                searchResults.classList.add("hidden");
              }
            });

            function escapeHtml(s: string) {
              return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
            }
          </script>
        </BaseLayout>
      );
    })()
  ) : (
    <BaseLayout title="Setup" description="Configure your Nostr blog">
      <div id="setup-root" class="min-h-[80vh] flex items-center justify-center px-4">
        <div class="w-full max-w-md">
          <div class="text-center mb-10">
            <h1 class="text-3xl font-bold mb-3">Nostr Blog</h1>
            <p class="text-gray-500 dark:text-gray-400">
              Enter the npub of the author whose posts you want to display.
              This can only be set once.
            </p>
          </div>

          <form id="setup-form" class="space-y-4">
            <div>
              <label for="npub" class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300">
                Nostr Public Key (npub)
              </label>
              <input
                id="npub"
                type="text"
                placeholder="npub1..."
                required
                autocomplete="off"
                spellcheck="false"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
              />
            </div>

            <div id="setup-error" class="hidden p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800">
              <p class="text-red-600 dark:text-red-400 text-sm font-medium"></p>
            </div>

            <button
              type="submit"
              class="w-full px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="setup-btn-text">Set Up Blog</span>
              <span id="setup-btn-loading" class="hidden">
                <svg class="inline-block animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Saving...
              </span>
            </button>
          </form>
        </div>
      </div>

      <script>
        document.getElementById("setup-form")?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const input = document.getElementById("npub");
          const error = document.getElementById("setup-error");
          const errorText = error?.querySelector("p");
          const btn = e.currentTarget.querySelector("button");
          const btnText = document.getElementById("setup-btn-text");
          const btnLoading = document.getElementById("setup-btn-loading");

          btn.disabled = true;
          if (btnText) btnText.classList.add("hidden");
          if (btnLoading) btnLoading.classList.remove("hidden");
          if (error) error.classList.add("hidden");

          try {
            const res = await fetch("/api/setup", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ npub: input.value.trim() }),
            });
            const data = await res.json();
            if (!res.ok) {
              if (errorText) errorText.textContent = data.error || "Failed to save";
              if (error) error.classList.remove("hidden");
              btn.disabled = false;
              if (btnText) btnText.classList.remove("hidden");
              if (btnLoading) btnLoading.classList.add("hidden");
              return;
            }
            window.location.reload();
          } catch {
            if (errorText) errorText.textContent = "Network error — check console for details";
            if (error) error.classList.remove("hidden");
            btn.disabled = false;
            if (btnText) btnText.classList.remove("hidden");
            if (btnLoading) btnLoading.classList.add("hidden");
          }
        });
      </script>
    </BaseLayout>
  )
}
